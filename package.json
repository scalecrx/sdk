{
  "name": "@scalecrx/sdk",
  "version": "0.4.3",
  "description": "TypeScript SDK for Scale AMM and VMM on Solana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scalecrx/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/scalecrx/sdk/issues"
  },
  "homepage": "https://github.com/scalecrx/sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/idl && cp src/idl/*.json dist/idl/",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.3"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@solana/web3.js": "^1.95.3"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "keywords": [
    "solana",
    "anchor",
    "amm",
    "vmm",
    "scale"
  ]
}
